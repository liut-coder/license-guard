# Copy to deploy/.env and replace every value marked change-me before production use.

POSTGRES_DB=license_guard
POSTGRES_USER=licenseguard
POSTGRES_PASSWORD=change-me-strong-password

# Internal Docker network URL used by licenseguard-server and licenseguard-migrate.
DATABASE_URL=postgres://licenseguard:change-me-strong-password@postgres:5432/license_guard?sslmode=disable

# Bind only to loopback when nginx terminates HTTPS on the host.
LICENSEGUARD_HTTP_PORT=127.0.0.1:8090

# Public URL shown to operators and used when generating client integration bundles.
LICENSEGUARD_PUBLIC_BASE_URL=https://licenseguard.example.com

# Comma-separated browser origins allowed to call the API. Use concrete HTTPS
# origins in production; keep "*" only for local development.
LG_CORS_ALLOWED_ORIGINS=https://licenseguard.example.com

# Enforce production safety checks: PostgreSQL store, explicit persistent key
# directory, and concrete CORS origins.
LG_PRODUCTION=true
